# =============================================================================
# config.env.example — additions for CYPFER openrelik-pipeline
# Merge these into your existing config.env.example
# =============================================================================

# ─── IP Address ───────────────────────────────────────────────────────────────
# IP_ADDRESS is now auto-detected at install time from the server's primary
# network interface. You do NOT need to set this in config.env.
#
# Override only if auto-detection picks the wrong address (e.g. multi-homed
# servers, VPNs, or custom routing):
# IP_ADDRESS=1.2.3.4

# --- GHCR credentials (shared with vr-config — same PAT, same vars) ----

# GitHub Container Registry credentials for pulling private images
GHCR_TOKEN=                             # GitHub PAT with read:packages scope (rotate before use)
GHCR_USER=                              # GitHub username (same var as used by vr-config)

# How long to wait for the OpenRelik API to become ready before running configure
OPENRELIK_WAIT_TIMEOUT=120              # seconds
OPENRELIK_WAIT_INTERVAL=5               # seconds between polls

# --- OpenRelik API Key Lifecycle --------------------------------------------

# Number of days the generated API key JWT should be valid.
# Requires OpenRelik v0.5.0+ (admin.py --days flag).
# Default is 10 years for machine-to-machine use.
# Set to a smaller value (e.g. 365) if your security policy requires annual rotation.
OPENRELIK_API_KEY_DAYS=3650

# Rotate the API key proactively this many days before it expires.
# The weekly cron job (rotate-api-key.sh) uses this threshold.
OPENRELIK_KEY_ROTATE_BEFORE_DAYS=30

# --- Additional worker versions (for workers Sprint 3 deploys from repo) ----
OPENRELIK_WORKER_HAYABUSA_VERSION=0.0.3    # check https://github.com/orgs/openrelik/packages for latest

# DO NOT set OPENRELIK_API_KEY manually.
# It is generated and managed automatically by install-hook.sh and rotate-api-key.sh.
# It is persisted to: /opt/openrelik-pipeline/.openrelik_api_key
# OPENRELIK_API_KEY=                    # auto-managed — do not set
