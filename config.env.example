# =============================================================================
# config.env.example
# Copy this to config.env and fill in all values before running install.sh
# NEVER commit config.env to git — it is listed in .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Target Environment - prod or dev
# -----------------------------------------------------------------------------
ENVIRONMENT=dev

# -----------------------------------------------------------------------------
# Deployment target
# -----------------------------------------------------------------------------
IP_ADDRESS=0.0.0.0

# -----------------------------------------------------------------------------
# Credentials — change all of these before deploying
# -----------------------------------------------------------------------------
TIMESKETCH_PASSWORD=CHANGE_ME_timesketch
VELOCIRAPTOR_PASSWORD=CHANGE_ME_velociraptor
OPENRELIK_ADMIN_PASSWORD=CHANGE_ME_openrelik

# ── Velociraptor configuration image ─────────────────────────────────────────
# Default: latest (main branch)
# For feature branch testing: feature-name
VR_CONFIG_IMAGE=ghcr.io/cypfer-inc/openrelik-vr-config:latest

# --- GHCR credentials (shared with vr-config — same PAT, same vars) ----
GHCR_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx   # GitHub PAT with read:packages scope
GHCR_USER=your-github-username        # GitHub username               

# -------------------------- IMPORTANT ----------------------------------------
# -----------------------------------------------------------------------------
# Do not change anything below, The digests will be periodically updated
# the OpenRelik api key is automatically updated during installation
# -----------------------------------------------------------------------------
# -----------------------------------------------------------------------------

# # --- OpenRelik Configure Container ---
OPENRELIK_WAIT_TIMEOUT=120         # Seconds to wait for OpenRelik to be ready
OPENRELIK_WAIT_INTERVAL=5          # Poll interval in seconds
#
# # --- OpenRelik API Key Rotation ---
OPENRELIK_API_KEY_DAYS=3650        # Days the generated API key is valid (default: 10 years)
OPENRELIK_KEY_ROTATE_BEFORE_DAYS=30 # Rotate proactively this many days before expiry
OPENRELIK_API_KEY=                 # Populated automatically by install-hook.sh; do not set manually

# -----------------------------------------------------------------------------
# FORK (tag-pinned, you control releases)
# -----------------------------------------------------------------------------
OPENRELIK_PIPELINE_VERSION=latest
OPENRELIK_WORKER_TIMESKETCH_VERSION="latest"

# -----------------------------------------------------------------------------
# OPENRELIK CORE (digest-pinned — run scripts/update-digests.sh)
# Format: sha256:<64-char hex>
# -----------------------------------------------------------------------------
OPENRELIK_SERVER_DIGEST=
OPENRELIK_MEDIATOR_DIGEST=
OPENRELIK_UI_DIGEST=

# -----------------------------------------------------------------------------
# OPENRELIK WORKERS (digest-pinned)
# -----------------------------------------------------------------------------
OPENRELIK_WORKER_PLASO_DIGEST=
OPENRELIK_WORKER_TIMESKETCH_DIGEST=

# -----------------------------------------------------------------------------
# INFRASTRUCTURE (digest-pinned)
# -----------------------------------------------------------------------------
REDIS_DIGEST=
TIMESKETCH_DIGEST=
VELOCIRAPTOR_DIGEST=
