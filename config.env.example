# =============================================================================
# config.env.example
# Copy this to config.env and fill in all values before running install.sh
# NEVER commit config.env to git — it is listed in .gitignore
#
# DIGEST FIELDS:
#   All *_DIGEST fields below are populated automatically by running:
#     bash scripts/update-digests.sh
#   Do not edit them by hand. After the script runs, review the diff,
#   check upstream changelogs, then commit config.env to your repo.
# =============================================================================

# -----------------------------------------------------------------------------
# Deployment target
# -----------------------------------------------------------------------------
IP_ADDRESS=0.0.0.0

# -----------------------------------------------------------------------------
# Credentials — change all of these before deploying
# -----------------------------------------------------------------------------
TIMESKETCH_PASSWORD=CHANGE_ME_timesketch
VELOCIRAPTOR_PASSWORD=CHANGE_ME_velociraptor
OPENRELIK_ADMIN_PASSWORD=CHANGE_ME_openrelik
POSTGRES_PASSWORD=CHANGE_ME_postgres
POSTGRES_USER=openrelik

# Set AFTER first boot — generate via OpenRelik admin UI or install.sh
OPENRELIK_API_KEY=YOUR_API_KEY_AFTER_FIRST_BOOT

# -----------------------------------------------------------------------------
# TIER 1 — YOUR FORK (tag-pinned, you control releases)
# -----------------------------------------------------------------------------
OPENRELIK_PIPELINE_VERSION=latest

# -----------------------------------------------------------------------------
# TIER 2 — OPENRELIK CORE (digest-pinned — run scripts/update-digests.sh)
# Format: sha256:<64-char hex>
# -----------------------------------------------------------------------------
OPENRELIK_SERVER_DIGEST=
OPENRELIK_MEDIATOR_DIGEST=
OPENRELIK_UI_DIGEST=

# -----------------------------------------------------------------------------
# TIER 2 — OPENRELIK WORKERS (digest-pinned)
# -----------------------------------------------------------------------------
OPENRELIK_WORKER_PLASO_DIGEST=
OPENRELIK_WORKER_TIMESKETCH_DIGEST=
OPENRELIK_WORKER_HAYABUSA_DIGEST=
OPENRELIK_WORKER_EXTRACTION_DIGEST=
OPENRELIK_WORKER_HASHER_DIGEST=
OPENRELIK_WORKER_GREP_DIGEST=
OPENRELIK_WORKER_STRINGS_DIGEST=

# -----------------------------------------------------------------------------
# TIER 3 — INFRASTRUCTURE (digest-pinned)
# -----------------------------------------------------------------------------
REDIS_DIGEST=
POSTGRES_DIGEST=

# -----------------------------------------------------------------------------
# THIRD-PARTY (digest-pinned)
# -----------------------------------------------------------------------------
TIMESKETCH_DIGEST=
VELOCIRAPTOR_DIGEST=
