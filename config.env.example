# =============================================================================
# config.env.example
# Copy this to config.env and fill in all values before running install.sh
# NEVER commit config.env to git — it is listed in .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Environment
# -----------------------------------------------------------------------------
ENVIRONMENT=dev                         # dev or prod

# -----------------------------------------------------------------------------
# Deployment target
# IP_ADDRESS is auto-detected at install time from the server's primary
# network interface. Override only if auto-detection picks the wrong address
# (e.g. multi-homed servers, VPNs, or custom routing).
# -----------------------------------------------------------------------------
# IP_ADDRESS=1.2.3.4

# -----------------------------------------------------------------------------
# Credentials — change ALL of these before deploying
# -----------------------------------------------------------------------------
TIMESKETCH_PASSWORD=CHANGE_ME_timesketch
VELOCIRAPTOR_PASSWORD=CHANGE_ME_velociraptor
OPENRELIK_ADMIN_PASSWORD=CHANGE_ME_openrelik
TS_ANALYST_PASSWORD=changeme_analyst    # leave blank to skip analyst account creation
TS_LEAD_PASSWORD=changeme_lead          # leave blank to skip lead account creation


# =============================================================================
# DO NOT CHANGE BELOW THIS LINE
# Digests are managed by scripts/update-digests.sh
# =============================================================================


# -----------------------------------------------------------------------------
# GHCR credentials — shared across vr-config, or-config, ts-config
# GitHub PAT with read:packages scope — rotate before use
# -----------------------------------------------------------------------------
GHCR_USER=
GHCR_TOKEN=

# -----------------------------------------------------------------------------
# Component config images
# Pin to a digest before production check-in (replace :latest)
# -----------------------------------------------------------------------------
VR_CONFIG_IMAGE=ghcr.io/cypfer-inc/openrelik-vr-config:latest
OR_CONFIG_IMAGE=ghcr.io/cypfer-inc/openrelik-or-config:latest
TS_CONFIG_IMAGE=ghcr.io/cypfer-inc/openrelik-ts-config:latest

# -----------------------------------------------------------------------------
# Timesketch post-install config (ts-config)
# TS_USERNAME / TS_PASSWORD are shared with the TS deployment block above
# -----------------------------------------------------------------------------
TS_DEFAULT_SKETCH=true                  # true = create sample sketch (dev); false = skip (prod)
TS_WAIT_TIMEOUT=120                     # seconds to wait for Timesketch to be ready
TS_WAIT_INTERVAL=5                      # seconds between readiness polls

# -----------------------------------------------------------------------------
# OpenRelik API key lifecycle
# The API key is generated and managed automatically by install.sh
# It is persisted to: /opt/openrelik-pipeline/.openrelik_api_key
# DO NOT set OPENRELIK_API_KEY manually.
# -----------------------------------------------------------------------------
OPENRELIK_WAIT_TIMEOUT=120              # seconds to wait for OpenRelik API
OPENRELIK_WAIT_INTERVAL=5               # seconds between polls
OPENRELIK_API_KEY_DAYS=3650             # JWT validity (days) — requires OpenRelik v0.5.0+
OPENRELIK_KEY_ROTATE_BEFORE_DAYS=30     # rotate key this many days before expiry
# OPENRELIK_API_KEY=                    # auto-managed — do not set

# -----------------------------------------------------------------------------
# Fork images (tag-pinned — you control releases)
# -----------------------------------------------------------------------------
OPENRELIK_PIPELINE_VERSION=latest
OPENRELIK_WORKER_TIMESKETCH_VERSION=latest
OPENRELIK_WORKER_HAYABUSA_VERSION=0.0.3    # check https://github.com/orgs/openrelik/packages

# -----------------------------------------------------------------------------
# OpenRelik core (digest-pinned — run scripts/update-digests.sh to refresh)
# Format: sha256:<64-char hex>
# -----------------------------------------------------------------------------
OPENRELIK_SERVER_DIGEST=
OPENRELIK_MEDIATOR_DIGEST=
OPENRELIK_UI_DIGEST=

# -----------------------------------------------------------------------------
# OpenRelik workers (digest-pinned)
# -----------------------------------------------------------------------------
OPENRELIK_WORKER_PLASO_DIGEST=
OPENRELIK_WORKER_TIMESKETCH_DIGEST=

# -----------------------------------------------------------------------------
# Infrastructure (digest-pinned)
# -----------------------------------------------------------------------------
REDIS_DIGEST=
TIMESKETCH_DIGEST=
VELOCIRAPTOR_DIGEST=

